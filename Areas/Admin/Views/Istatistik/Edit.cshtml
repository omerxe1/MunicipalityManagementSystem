@model kocaaliv2.Models.Istatistik
@{
    ViewData["Title"] = "İstatistik Düzenle";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4><i class="fas fa-edit me-2"></i>İstatistik Düzenle</h4>
    <a href="@Url.Action("Index", "Istatistik", new { area = "Admin" })" class="btn btn-secondary">
        <i class="fas fa-arrow-left me-2"></i>Geri Dön
    </a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Baslik" class="form-label">Başlık <span class="text-danger">*</span></label>
                <input asp-for="Baslik" class="form-control" placeholder="Örn: Nüfus, Park, Tesis" />
                <span asp-validation-for="Baslik" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Deger" class="form-label">Değer <span class="text-danger">*</span></label>
                <input asp-for="Deger" class="form-control" placeholder="Örn: 76.659, 100, 502.151 M²" />
                <span asp-validation-for="Deger" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Ikon" class="form-label">İkon Sınıfı</label>
                <input asp-for="Ikon" class="form-control" placeholder="Örn: fas fa-users, fas fa-tree" />
                <small class="form-text text-muted">Font Awesome ikon sınıfı (örn: fas fa-users)</small>
                <span asp-validation-for="Ikon" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="SiraNo" class="form-label">Sıra No</label>
                    <input asp-for="SiraNo" type="number" class="form-control" />
                    <span asp-validation-for="SiraNo" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <div class="form-check mt-4">
                        <input asp-for="AktifMi" class="form-check-input" type="checkbox" />
                        <label asp-for="AktifMi" class="form-check-label">Aktif</label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Kaydet
                </button>
                <a href="@Url.Action("Index", "Istatistik", new { area = "Admin" })" class="btn btn-secondary">
                    <i class="fas fa-times me-2"></i>İptal
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}



