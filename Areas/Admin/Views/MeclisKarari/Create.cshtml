@model kocaaliv2.Models.MeclisKarari
@{
    ViewData["Title"] = "Yeni Meclis Kararı Ekle";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4><i class="fas fa-plus-circle me-2"></i>Yeni Meclis Kararı Ekle</h4>
    <a href="@Url.Action("Index", "MeclisKarari", new { area = "Admin" })" class="btn btn-secondary">
        <i class="fas fa-arrow-left me-2"></i>Geri Dön
    </a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Baslik" class="form-label">Başlık <span class="text-danger">*</span></label>
                <input asp-for="Baslik" class="form-control" />
                <span asp-validation-for="Baslik" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="KararNo" class="form-label">Karar No</label>
                <input asp-for="KararNo" class="form-control" />
                <span asp-validation-for="KararNo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Tarih" class="form-label">Tarih <span class="text-danger">*</span></label>
                <input asp-for="Tarih" type="datetime-local" class="form-control" />
                <span asp-validation-for="Tarih" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Aciklama" class="form-label">Açıklama</label>
                <textarea asp-for="Aciklama" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Aciklama" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label for="pdfDosyasi" class="form-label">PDF Dosyası Yükle</label>
                <input type="file" name="pdfDosyasi" id="pdfDosyasi" class="form-control" accept="application/pdf" />
                <small class="form-text text-muted">Sadece PDF dosyaları yüklenebilir. Maksimum dosya boyutu: 10MB</small>
            </div>

            <div class="mb-3">
                <label asp-for="PdfUrl" class="form-label">Veya PDF URL</label>
                <input asp-for="PdfUrl" class="form-control" placeholder="https://..." />
                <small class="form-text text-muted">Dosya yükleme yerine manuel URL de girebilirsiniz</small>
                <span asp-validation-for="PdfUrl" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="SiraNo" class="form-label">Sıra No</label>
                    <input asp-for="SiraNo" type="number" class="form-control" />
                    <span asp-validation-for="SiraNo" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <div class="form-check mt-4">
                        <input asp-for="AktifMi" class="form-check-input" type="checkbox" />
                        <label asp-for="AktifMi" class="form-check-label">Aktif</label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Kaydet
                </button>
                <a href="@Url.Action("Index", "MeclisKarari", new { area = "Admin" })" class="btn btn-secondary">
                    <i class="fas fa-times me-2"></i>İptal
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

