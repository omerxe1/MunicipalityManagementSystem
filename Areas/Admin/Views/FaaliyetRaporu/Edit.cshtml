@model kocaaliv2.Models.FaaliyetRaporu
@{
    ViewData["Title"] = "Faaliyet Raporu Düzenle";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4><i class="fas fa-edit me-2"></i>Faaliyet Raporu Düzenle</h4>
    <a href="@Url.Action("Index", "FaaliyetRaporu", new { area = "Admin" })" class="btn btn-secondary">
        <i class="fas fa-arrow-left me-2"></i>Geri Dön
    </a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="OlusturmaTarihi" />
            
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Yil" class="form-label">Yıl <span class="text-danger">*</span></label>
                <input asp-for="Yil" type="number" class="form-control" min="2000" max="2100" />
                <span asp-validation-for="Yil" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Url" class="form-label">URL</label>
                <input asp-for="Url" class="form-control" placeholder="https://..." />
                <span asp-validation-for="Url" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <div class="form-check">
                    <input asp-for="AktifMi" class="form-check-input" type="checkbox" />
                    <label asp-for="AktifMi" class="form-check-label">Aktif</label>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Güncelle
                </button>
                <a href="@Url.Action("Index", "FaaliyetRaporu", new { area = "Admin" })" class="btn btn-secondary">
                    <i class="fas fa-times me-2"></i>İptal
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}






