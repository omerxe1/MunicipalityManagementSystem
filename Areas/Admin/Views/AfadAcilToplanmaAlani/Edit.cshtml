@model kocaaliv2.Models.AfadAcilToplanmaAlani
@{
    ViewData["Title"] = "AFAD Acil Toplanma Alanı Düzenle";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4><i class="fas fa-edit me-2"></i>AFAD Acil Toplanma Alanı Düzenle</h4>
    <a href="@Url.Action("Index", "AfadAcilToplanmaAlani", new { area = "Admin" })" class="btn btn-secondary">
        <i class="fas fa-arrow-left me-2"></i>Geri Dön
    </a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Adi" class="form-label">Adı <span class="text-danger">*</span></label>
                <input asp-for="Adi" class="form-control" />
                <span asp-validation-for="Adi" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Ilce" class="form-label">İlçe <span class="text-danger">*</span></label>
                    <input asp-for="Ilce" class="form-control" />
                    <span asp-validation-for="Ilce" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Mahalle" class="form-label">Mahalle <span class="text-danger">*</span></label>
                    <input asp-for="Mahalle" class="form-control" />
                    <span asp-validation-for="Mahalle" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Enlem" class="form-label">Enlem</label>
                    <input asp-for="Enlem" class="form-control" />
                    <span asp-validation-for="Enlem" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Boylam" class="form-label">Boylam</label>
                    <input asp-for="Boylam" class="form-control" />
                    <span asp-validation-for="Boylam" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4">
                    <div class="form-check">
                        <input asp-for="Elektrik" class="form-check-input" type="checkbox" />
                        <label asp-for="Elektrik" class="form-check-label">Elektrik</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-check">
                        <input asp-for="Yol" class="form-check-input" type="checkbox" />
                        <label asp-for="Yol" class="form-check-label">Yol</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-check">
                        <input asp-for="WcKanSistemi" class="form-check-input" type="checkbox" />
                        <label asp-for="WcKanSistemi" class="form-check-label">WC/Kan Sistemi</label>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="SiraNo" class="form-label">Sıra No</label>
                    <input asp-for="SiraNo" type="number" class="form-control" />
                    <span asp-validation-for="SiraNo" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <div class="form-check mt-4">
                        <input asp-for="AktifMi" class="form-check-input" type="checkbox" />
                        <label asp-for="AktifMi" class="form-check-label">Aktif</label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Güncelle
                </button>
                <a href="@Url.Action("Index", "AfadAcilToplanmaAlani", new { area = "Admin" })" class="btn btn-secondary">
                    <i class="fas fa-times me-2"></i>İptal
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}






