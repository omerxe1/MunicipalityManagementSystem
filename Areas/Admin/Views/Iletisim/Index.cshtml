@model IEnumerable<kocaaliv2.Models.IletisimBasvuru>
@{
    ViewData["Title"] = "İletişim Başvuruları";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4><i class="fas fa-envelope me-2"></i>İletişim Başvuruları</h4>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Ad Soyad</th>
                        <th>Email</th>
                        <th>Konu</th>
                        <th>Tarih</th>
                        <th>Durum</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.AdSoyad</td>
                                <td>@item.Email</td>
                                <td>@item.Konu</td>
                                <td>@item.Tarih.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>
                                    @if (item.OkunduMu)
                                    {
                                        <span class="badge bg-success">Okundu</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning">Okunmadı</span>
                                    }
                                </td>
                                <td>
                                    <a href="@Url.Action("Details", "Iletisim", new { area = "Admin", id = item.Id })" class="btn btn-sm btn-info">
                                        <i class="fas fa-eye"></i> Detay
                                    </a>
                                    <form method="post" action="@Url.Action("Delete", "Iletisim", new { area = "Admin", id = item.Id })" style="display:inline;" onsubmit="return confirm('Bu başvuruyu silmek istediğinize emin misiniz?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="fas fa-trash"></i> Sil
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted">
                                <i class="fas fa-inbox me-2"></i>Henüz başvuru bulunmamaktadır.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>






