@model IEnumerable<kocaaliv2.Models.PopupAnnouncement>
@{
    ViewData["Title"] = "Popup Duyuru Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4><i class="fas fa-window-restore me-2"></i>Popup Duyuru Yönetimi</h4>
    <a href="@Url.Action("Create", "PopupAnnouncement", new { area = "Admin" })" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>Yeni Popup Ekle
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Başlık</th>
                        <th>İkon</th>
                        <th>Sıra</th>
                        <th>Aktif</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.Title</td>
                                <td><i class="@item.Icon"></i></td>
                                <td>@item.SiraNo</td>
                                <td>
                                    @if (item.AktifMi)
                                    {
                                        <span class="badge bg-success">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Pasif</span>
                                    }
                                </td>
                                <td>
                                    <a href="@Url.Action("Edit", "PopupAnnouncement", new { area = "Admin", id = item.Id })" class="btn btn-sm btn-warning">
                                        <i class="fas fa-edit"></i> Düzenle
                                    </a>
                                    <form method="post" action="@Url.Action("Delete", "PopupAnnouncement", new { area = "Admin", id = item.Id })" style="display:inline;" onsubmit="return confirm('Bu kaydı silmek istediğinize emin misiniz?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="fas fa-trash"></i> Sil
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">
                                <i class="fas fa-inbox me-2"></i>Henüz kayıt eklenmemiş.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>






