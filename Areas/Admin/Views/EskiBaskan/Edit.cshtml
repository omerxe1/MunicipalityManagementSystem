@model kocaaliv2.Models.EskiBaskan
@{
    ViewData["Title"] = "Eski Başkan Düzenle";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4><i class="fas fa-edit me-2"></i>Eski Başkan Düzenle</h4>
    <a href="@Url.Action("Index", "EskiBaskan", new { area = "Admin" })" class="btn btn-secondary">
        <i class="fas fa-arrow-left me-2"></i>Geri Dön
    </a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="AdSoyad" class="form-label">Ad Soyad <span class="text-danger">*</span></label>
                <input asp-for="AdSoyad" class="form-control" />
                <span asp-validation-for="AdSoyad" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Donem" class="form-label">Dönem <span class="text-danger">*</span></label>
                <input asp-for="Donem" class="form-control" />
                <span asp-validation-for="Donem" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ResimYolu" class="form-label">Resim Yolu <span class="text-danger">*</span></label>
                <input asp-for="ResimYolu" class="form-control" placeholder="https://..." />
                <span asp-validation-for="ResimYolu" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="SiraNo" class="form-label">Sıra No</label>
                    <input asp-for="SiraNo" type="number" class="form-control" />
                    <span asp-validation-for="SiraNo" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <div class="form-check mt-4">
                        <input asp-for="AktifMi" class="form-check-input" type="checkbox" />
                        <label asp-for="AktifMi" class="form-check-label">Aktif</label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Güncelle
                </button>
                <a href="@Url.Action("Index", "EskiBaskan", new { area = "Admin" })" class="btn btn-secondary">
                    <i class="fas fa-times me-2"></i>İptal
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}






