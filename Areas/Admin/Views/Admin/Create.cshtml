@model kocaaliv2.Models.Admin
@{
    ViewData["Title"] = "Yeni Kullanıcı Ekle";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4><i class="fas fa-plus-circle me-2"></i>Yeni Kullanıcı Ekle</h4>
    <a href="@Url.Action("Index", "Admin", new { area = "Admin" })" class="btn btn-secondary">
        <i class="fas fa-arrow-left me-2"></i>Geri Dön
    </a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="KullaniciAdi" class="form-label">Kullanıcı Adı <span class="text-danger">*</span></label>
                <input asp-for="KullaniciAdi" class="form-control" required />
                <span asp-validation-for="KullaniciAdi" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label for="sifre" class="form-label">Şifre <span class="text-danger">*</span></label>
                <input type="password" name="sifre" id="sifre" class="form-control" required />
            </div>

            <div class="mb-3">
                <label asp-for="Rol" class="form-label">Rol <span class="text-danger">*</span></label>
                <select asp-for="Rol" class="form-control" required>
                    <option value="">-- Rol Seçin --</option>
                    <option value="Editor">Editor</option>
                    <option value="Admin">Admin</option>
                </select>
                <span asp-validation-for="Rol" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <div class="form-check">
                    <input asp-for="AktifMi" class="form-check-input" type="checkbox" checked="checked" />
                    <label asp-for="AktifMi" class="form-check-label">Aktif</label>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Kaydet
                </button>
                <a href="@Url.Action("Index", "Admin", new { area = "Admin" })" class="btn btn-secondary">
                    <i class="fas fa-times me-2"></i>İptal
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}


