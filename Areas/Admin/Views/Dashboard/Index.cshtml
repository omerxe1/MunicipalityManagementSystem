@{
    ViewData["Title"] = "Dashboard";
}

<!-- Hoş Geldiniz Bölümü -->
<div class="row mb-4">
    <div class="col-12">
        <div class="stat-card" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border-left: none;">
            <h2 style="color: white; margin: 0;">
                <i class="fas fa-hand-sparkles me-2"></i>Admin Paneline Hoş Geldiniz
            </h2>
            <p style="color: rgba(255,255,255,0.9); margin: 0.5rem 0 0 0;">
                Merhaba <strong>@ViewBag.KullaniciAdi</strong>, sisteme başarıyla giriş yaptınız.
            </p>
        </div>
    </div>
</div>

<!-- İstatistik Kartları -->
<div class="row mb-4">
    <div class="col-md-6 mb-3">
        <div class="stat-card warning">
            <div class="stat-card-icon" style="color: #f39c12;">
                <i class="fas fa-comments"></i>
            </div>
            <div class="stat-card-value">@ViewBag.OkunmamisIstekVeOneriSayisi</div>
            <div class="stat-card-label">Okunmamış İstek ve Öneri</div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="stat-card primary">
            <div class="stat-card-icon" style="color: #3498db;">
                <i class="fas fa-calendar-alt"></i>
            </div>
            <div class="stat-card-value">@ViewBag.YaklasanEtkinlikSayisi</div>
            <div class="stat-card-label">Yaklaşan Etkinlik</div>
        </div>
    </div>
</div>

<!-- Bilgi Kartı -->
<div class="row">
    <div class="col-12">
        <div class="stat-card" style="background: white;">
            <h5 style="color: #2c3e50; margin-bottom: 1rem;">
                <i class="fas fa-info-circle me-2" style="color: #3498db;"></i>Sistem Bilgisi
            </h5>
            <div class="row">
                <div class="col-md-6">
                    <p style="margin-bottom: 0.5rem;">
                        <strong>Kullanıcı Adı:</strong> <span style="color: #7f8c8d;">@ViewBag.KullaniciAdi</span>
                    </p>
                    <p style="margin-bottom: 0.5rem;">
                        <strong>Rol:</strong> <span class="user-role" style="display: inline-block;">@ViewBag.Rol</span>
                    </p>
                </div>
                <div class="col-md-6">
                    <p style="margin-bottom: 0.5rem;">
                        <strong>Giriş Zamanı:</strong> <span style="color: #7f8c8d;">@DateTime.Now.ToString("dd.MM.yyyy HH:mm")</span>
                    </p>
                    <p style="margin-bottom: 0.5rem;">
                        <strong>Durum:</strong> <span style="color: #2ecc71;"><i class="fas fa-circle" style="font-size: 0.5rem;"></i> Aktif</span>
                    </p>
                </div>
            </div>
            <hr style="margin: 1rem 0;">
            <p style="color: #7f8c8d; margin: 0; font-size: 0.875rem;">
            </p>
        </div>
    </div>
</div>

