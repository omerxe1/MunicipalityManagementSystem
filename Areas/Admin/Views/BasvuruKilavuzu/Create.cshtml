@model kocaaliv2.Models.BasvuruKilavuzu
@{
    ViewData["Title"] = "Yeni Başvuru Kılavuzu Ekle";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4><i class="fas fa-plus-circle me-2"></i>Yeni Başvuru Kılavuzu Ekle</h4>
    <a href="@Url.Action("Index", "BasvuruKilavuzu", new { area = "Admin" })" class="btn btn-secondary">
        <i class="fas fa-arrow-left me-2"></i>Geri Dön
    </a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Baslik" class="form-label">Başlık <span class="text-danger">*</span></label>
                <input asp-for="Baslik" class="form-control" />
                <span asp-validation-for="Baslik" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Aciklama" class="form-label">Açıklama</label>
                <textarea asp-for="Aciklama" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Aciklama" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DosyaUrl" class="form-label">Dosya URL</label>
                <input asp-for="DosyaUrl" class="form-control" placeholder="https://..." />
                <span asp-validation-for="DosyaUrl" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PdfUrl" class="form-label">PDF URL</label>
                <input asp-for="PdfUrl" class="form-control" placeholder="https://..." />
                <span asp-validation-for="PdfUrl" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DisLink" class="form-label">Dış Link</label>
                <input asp-for="DisLink" class="form-control" placeholder="https://..." />
                <span asp-validation-for="DisLink" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Sira" class="form-label">Sıra</label>
                    <input asp-for="Sira" type="number" class="form-control" />
                    <span asp-validation-for="Sira" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <div class="form-check mt-4">
                        <input asp-for="AktifMi" class="form-check-input" type="checkbox" />
                        <label asp-for="AktifMi" class="form-check-label">Aktif</label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Kaydet
                </button>
                <a href="@Url.Action("Index", "BasvuruKilavuzu", new { area = "Admin" })" class="btn btn-secondary">
                    <i class="fas fa-times me-2"></i>İptal
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}






