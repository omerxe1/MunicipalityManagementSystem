@model kocaaliv2.Models.BilgiEdinmeBasvuru
@{
    ViewData["Title"] = "Bilgi Edinme Başvuru Detayı";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4><i class="fas fa-info-circle me-2"></i>Bilgi Edinme Başvuru Detayı</h4>
    <a href="@Url.Action("Index", "BilgiEdinmeBasvuru", new { area = "Admin" })" class="btn btn-secondary">
        <i class="fas fa-arrow-left me-2"></i>Geri Dön
    </a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <h5 class="mb-3">Şahıs Türü: <span class="badge bg-info">@Model.SahisTuru</span></h5>

        @if (Model.SahisTuru == "Sahis")
        {
            <div class="row mb-3">
                <div class="col-md-6">
                    <strong>Ad:</strong>
                    <p>@(Model.Ad ?? "-")</p>
                </div>
                <div class="col-md-6">
                    <strong>Soyad:</strong>
                    <p>@(Model.Soyad ?? "-")</p>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <strong>Kimlik No:</strong>
                    <p>@(Model.KimlikNo ?? "-")</p>
                </div>
                <div class="col-md-6">
                    <strong>Doğum Tarihi:</strong>
                    <p>@(Model.DogumGunu.HasValue && Model.DogumAyi.HasValue ? $"{Model.DogumGunu.Value}.{Model.DogumAyi.Value}.{Model.DogumYili}" : "-")</p>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <strong>Ev Telefonu:</strong>
                    <p>@(Model.EvTelefonu ?? "-")</p>
                </div>
                <div class="col-md-6">
                    <strong>Cep Telefonu:</strong>
                    <p>@(Model.CepTelefonu ?? "-")</p>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <strong>Email:</strong>
                    <p>@(Model.Email ?? "-")</p>
                </div>
                <div class="col-md-6">
                    <strong>İletişim Adresi:</strong>
                    <p>@(Model.IletisimAdresi ?? "-")</p>
                </div>
            </div>

            <div class="mb-3">
                <strong>Başvuru Metni:</strong>
                <div class="border p-3 mt-2" style="background-color: #f8f9fa; border-radius: 5px;">
                    @(Model.BasvuruMetni ?? "-")
                </div>
            </div>

            <div class="mb-3">
                <strong>Cevap Nasıl Verilsin:</strong>
                <p>@(Model.CevapNasilVerilsin ?? "-")</p>
            </div>
        }
        else
        {
            <div class="row mb-3">
                <div class="col-md-6">
                    <strong>Unvan:</strong>
                    <p>@(Model.Unvan ?? "-")</p>
                </div>
                <div class="col-md-6">
                    <strong>Vergi Dairesi:</strong>
                    <p>@(Model.VergiDairesi ?? "-")</p>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <strong>Vergi No:</strong>
                    <p>@(Model.VergiNo ?? "-")</p>
                </div>
                <div class="col-md-6">
                    <strong>İş Telefonu:</strong>
                    <p>@(Model.IsTelefonu ?? "-")</p>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <strong>Cep Telefonu:</strong>
                    <p>@(Model.TuzelCepTelefonu ?? "-")</p>
                </div>
                <div class="col-md-6">
                    <strong>Email:</strong>
                    <p>@(Model.TuzelEmail ?? "-")</p>
                </div>
            </div>

            <div class="mb-3">
                <strong>İletişim Adresi:</strong>
                <p>@(Model.TuzelIletisimAdresi ?? "-")</p>
            </div>

            <div class="mb-3">
                <strong>Başvuru Metni:</strong>
                <div class="border p-3 mt-2" style="background-color: #f8f9fa; border-radius: 5px;">
                    @(Model.TuzelBasvuruMetni ?? "-")
                </div>
            </div>

            <div class="mb-3">
                <strong>Cevap Nasıl Verilsin:</strong>
                <p>@(Model.TuzelCevapNasilVerilsin ?? "-")</p>
            </div>
        }

        <div class="row mb-3">
            <div class="col-md-6">
                <strong>Tarih:</strong>
                <p>@Model.OlusturmaTarihi.ToString("dd.MM.yyyy HH:mm")</p>
            </div>
            <div class="col-md-6">
                <strong>Durum:</strong>
                @if (Model.OkunduMu)
                {
                    <span class="badge bg-success">Okundu</span>
                }
                else
                {
                    <span class="badge bg-warning">Okunmadı</span>
                }
            </div>
        </div>

        <div class="d-flex gap-2">
            <a href="@Url.Action("Index", "BilgiEdinmeBasvuru", new { area = "Admin" })" class="btn btn-secondary">
                <i class="fas fa-arrow-left me-2"></i>Geri Dön
            </a>
            <form method="post" action="@Url.Action("Delete", "BilgiEdinmeBasvuru", new { area = "Admin", id = Model.Id })" style="display:inline;" onsubmit="return confirm('Bu başvuruyu silmek istediğinize emin misiniz?');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash me-2"></i>Sil
                </button>
            </form>
        </div>
    </div>
</div>






