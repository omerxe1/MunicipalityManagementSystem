@{
    // Müdürlükler sayfası - Alt sayfa layout'unu kullanır
    Layout = "_AltSayfaLayout";
    ViewData["Title"] = "Müdürlükler";
    ViewData["PageTitle"] = "Müdürlükler";
    ViewData["ContentTitle"] = "Müdürlükler";
    
    // Breadcrumb verileri
    ViewBag.Breadcrumbs = new[]
    {
        new { Text = "Anasayfa", Url = (string?)(Url.Action("Index", "Home") ?? "#") },
        new { Text = "Belediyemiz", Url = (string?)"#" },
        new { Text = "Müdürlükler", Url = (string?)null }
    };
    
    // Hızlı menü öğeleri
    ViewBag.QuickMenuItems = new[]
    {
        new { Text = "Meclis Üyeleri", Url = (string?)"#", IsActive = false },
        new { Text = "Meclis Kararları", Url = (string?)"#", IsActive = false },
        new { Text = "Kocaali Hakkında", Url = (string?)"#", IsActive = false },
        new { Text = "Nöbetçi Eczaneler", Url = (string?)"#", IsActive = false },
        new { Text = "Haberler", Url = (string?)(Url.Action("Index", "Haberler") ?? "#"), IsActive = false },
        new { Text = "Duyurular", Url = (string?)"#", IsActive = false },
        new { Text = "Etkinlikler", Url = (string?)(Url.Action("Index", "Etkinlik") ?? "#"), IsActive = false },
        new { Text = "Nöbetçi Zabıta Listesi", Url = (string?)"#", IsActive = false },
        new { Text = "Afad Acil Toplanma Alanları", Url = (string?)"#", IsActive = false },
        new { Text = "Salon Tahsis", Url = (string?)"#", IsActive = false },
        new { Text = "Ulaşım Bizden Başarı Sizden", Url = (string?)"#", IsActive = false }
    };
    
    ViewBag.ShowBackButton = true;
}

<!-- Müdürlükler Listesi -->
<div class="mudurlukler-list">
    <a asp-controller="Mudurlukler" asp-action="BasinYayinHalklaIliskiler" class="mudurlukler-item">
        <i class="fas fa-chevron-right"></i>
        <span>Basın Yayın ve Halkla İlişkiler Müdürlüğü</span>
    </a>
    <a asp-controller="Mudurlukler" asp-action="KulturVeSosyalIsler" class="mudurlukler-item">
        <i class="fas fa-chevron-right"></i>
        <span>Kültür ve Sosyal İşler Müdürlüğü</span>
    </a>
    <a asp-controller="Mudurlukler" asp-action="FenIsleri" class="mudurlukler-item">
        <i class="fas fa-chevron-right"></i>
        <span>Fen İşleri Müdürlüğü</span>
    </a>
    <a asp-controller="Mudurlukler" asp-action="MaliHizmetler" class="mudurlukler-item">
        <i class="fas fa-chevron-right"></i>
        <span>Mali Hizmetler Müdürlüğü</span>
    </a>
    <a asp-controller="Mudurlukler" asp-action="RuhsatVeDenetim" class="mudurlukler-item">
        <i class="fas fa-chevron-right"></i>
        <span>Ruhsat ve Denetim Müdürlüğü</span>
    </a>
    <a asp-controller="Mudurlukler" asp-action="YaziIsleri" class="mudurlukler-item">
        <i class="fas fa-chevron-right"></i>
        <span>Yazı İşleri Müdürlüğü</span>
    </a>
    <a asp-controller="Mudurlukler" asp-action="Zabita" class="mudurlukler-item">
        <i class="fas fa-chevron-right"></i>
        <span>Zabıta Müdürlüğü</span>
    </a>
    <a asp-controller="Mudurlukler" asp-action="BilgiIslem" class="mudurlukler-item">
        <i class="fas fa-chevron-right"></i>
        <span>Bilgi İşlem Müdürlüğü</span>
    </a>
    <a asp-controller="Mudurlukler" asp-action="CevreKorumaVeKontrol" class="mudurlukler-item">
        <i class="fas fa-chevron-right"></i>
        <span>Çevre Koruma ve Kontrol Müdürlüğü</span>
    </a>
    <a asp-controller="Mudurlukler" asp-action="ImarVeSehircilik" class="mudurlukler-item">
        <i class="fas fa-chevron-right"></i>
        <span>İmar ve Şehircilik Müdürlüğü</span>
    </a>
</div>


