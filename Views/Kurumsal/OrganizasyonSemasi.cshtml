<script>
    // Panel scroll özelliği - mouse wheel ile yatay kaydırma
    document.addEventListener('DOMContentLoaded', function() {
        const scrollPanel = document.getElementById('orgPanelScroll');
        if (scrollPanel) {
            scrollPanel.addEventListener('wheel', function(e) {
                if (e.deltaY !== 0) {
                    e.preventDefault();
                    scrollPanel.scrollLeft += e.deltaY;
                }
            });
        }
    });
</script>

