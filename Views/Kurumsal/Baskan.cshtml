@{
    ViewData["Title"] = "Belediye Başkanı";
    ViewBag.HideNavbar = true;
}

<section class="baskan-section">
    <div class="container-fluid px-0">
        <div class="row g-0">
            <div class="col-lg-4 col-md-12">
                <div class="baskan-left-panel">
                    <div class="baskan-image-container">
                        <img src="~/images/baskan.png" alt="Belediye Başkanı" class="baskan-image">
                    </div>
                    <div class="baskan-social-icons">
                        <a href="https://www.facebook.com/kocaalibld/" target="_blank"><i class="fab fa-facebook-f"></i></a>
                        <a href="https://x.com/KocaaliBld" target="_blank"><i class="fab fa-twitter"></i></a>
                        <a href="https://www.instagram.com/kocaali.bld/" target="_blank"><i class="fab fa-instagram"></i></a>
                    </div>
                </div>
            </div>

            <div class="col-lg-8 col-md-12">
                <div class="baskan-content-panel">
                    <div class="baskan-nav-menu">
                        <div class="baskan-nav-tabs">
                            <a href="#" class="baskan-nav-tab active" data-tab="ozgecmis">Başkanın Özgeçmişi</a>
                            <a asp-controller="Kurumsal" asp-action="BaskanMesaj" class="baskan-nav-tab" data-tab="mesaj">Başkana Mesaj Gönder</a>
                            <a asp-controller="Kurumsal" asp-action="BaskanFotograflari" class="baskan-nav-tab" data-tab="fotograflar">Başkan'ın Fotoğrafları</a>
                            <a href="#" class="baskan-nav-tab" data-tab="videolar">Başkanın Videoları</a>
                        </div>
                        <button class="baskan-close-btn" onclick="window.history.back()">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>

                    <div class="baskan-content">
                        <h1 class="baskan-name">Turan Yüzücü</h1>

                        <div class="baskan-section-content" id="ozgecmis-content">
                            <div class="baskan-text">
                                <p>
                                    1967 yılında Sakarya Kocaali' de doğdu, Eskişehir Anadolu Üniversitesi İşletme
                                    Fakültesinden mezun oldu. Turan Yüzücü 1987-2005 yılları arasında Kocaali
                                    Belediyesinde Yazı İşleri Müdürlüğü, Evlendirme Memurluğu ve Personel Müdürlüğü
                                    olarak görev yaptı. 2005 yılından günümüze kadar Karasu Kaymakamlık Yazı İşleri
                                    Müdürlüğü görevini başarıyla yaptı.

                                    31 Mart 2024 Yerel seçimleri için Ak Parti Kocaali Belediye Başkan adayı olarak
                                    gösterilen Yüzücü, Yapılan seçimler sonrası Kocaali Belediye Başkanı olarak seçildi.
                                    Turan Yüzücü evli ve 3 çocuk babasıdır.

                                </p>
                                <p>
                                    Belediye Başkanlığı görevine seçilmesinin ardından, şehrimizin
                                    gelişimi ve vatandaşlarımızın refahı için çalışmalarına devam
                                    etmektedir. Çalışan belediyecilik anlayışıyla, şeffaf ve katılımcı
                                    bir yönetim modeli benimsemektedir.
                                </p>
                            </div>
                        </div>

                        <div class="baskan-section-content" id="mesaj-content" style="display: none;">
                            <div class="baskan-text">
                                <p>Başkana mesaj gönderme formu buraya eklenecek.</p>
                            </div>
                        </div>

                        <div class="baskan-section-content" id="fotograflar-content" style="display: none;">
                            @if (ViewBag.Photos != null && ((List<kocaaliv2.Models.Photo>)ViewBag.Photos).Any())
                            {
                                <div class="baskan-photos-grid">
                                    @foreach (var photo in (List<kocaaliv2.Models.Photo>)ViewBag.Photos)
                                    {
                                        <div class="baskan-photo-item">
                                            <img src="@photo.ImageUrl" alt="@photo.Title" class="baskan-photo-img">
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="baskan-text">
                                    <p>Henüz fotoğraf eklenmemiş.</p>
                                </div>
                            }
                        </div>

                        <div class="baskan-section-content" id="videolar-content" style="display: none;">
                            <div class="baskan-text">
                                <p>Başkan'ın videoları buraya eklenecek.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .baskan-section {
        padding: 0;
        background: #f8f9fa;
        min-height: 100vh;
    }

    .baskan-left-panel {
        background: linear-gradient(135deg, rgb(4, 22, 85) 0%, rgb(4, 22, 85) 100%);
        padding: 80px 50px 60px;
        height: 100vh;
        min-height: 800px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

    .baskan-left-panel::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 100%;
        height: 100%;
        background: url('/images/Kocaali_Belediyesi_logo(4).svg.PNG') no-repeat center;
        background-size: 130%;
        opacity: 0.15;
        z-index: 0;
    }

    .baskan-image-container {
        text-align: center;
        width: 100%;
        position: relative;
        z-index: 1;
        margin-bottom: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 80px 50px 0;
    }

    .baskan-image {
        width: 130%;
        max-width: 900px;
        height: auto;
        object-fit: cover;
        display: block;
    }

    .baskan-social-icons {
        position: absolute;
        bottom: 40px;
        left: 50px;
        display: flex;
        gap: 20px;
        z-index: 1;
    }

    .baskan-social-icons a {
        color: white;
        font-size: 24px;
        width: 45px;
        height: 45px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 0;
        background: rgba(255, 255, 255, 0.1);
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .baskan-social-icons a:hover {
        background: white;
        color: #1a237e;
        transform: translateY(-3px);
    }

    .baskan-content-panel {
        background: white;
        padding: 0;
        height: 100vh;
        min-height: 800px;
        display: flex;
        flex-direction: column;
    }

    .baskan-nav-menu {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: white;
        border-bottom: 1px solid #e9ecef;
        padding: 0;
        position: relative;
    }

    .baskan-nav-tabs {
        display: flex;
        gap: 0;
        padding: 0;
        margin: 0;
        flex: 1;
    }

    .baskan-nav-tab {
        padding: 25px 35px;
        text-decoration: none;
        color: #6c757d;
        font-weight: 500;
        font-size: 15px;
        border-bottom: 3px solid transparent;
        transition: all 0.3s ease;
        position: relative;
        background: white;
        border: none;
        cursor: pointer;
        min-height: 70px;
    }

    .baskan-nav-tab:hover {
        color: rgb(4, 22, 85);
        background: #f8f9fa;
    }

    .baskan-nav-tab.active {
        color: rgb(4, 22, 85);
        border-bottom-color: rgb(4, 22, 85);
        background: white;
        font-weight: 600;
    }

    .baskan-close-btn {
        width: 70px;
        height: 70px;
        background: rgb(4, 22, 85);
        border: none;
        color: white;
        font-size: 24px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        margin-right: 0;
    }

    .baskan-close-btn:hover {
        background: rgb(3, 18, 70);
        transform: scale(1.05);
    }

    .baskan-content {
        padding: 50px 60px;
        flex: 1;
        overflow-y: auto;
    }

    .baskan-name {
        font-size: 42px;
        font-weight: 700;
        color: rgb(4, 22, 85);
        margin-bottom: 30px;
        line-height: 1.2;
    }

    .baskan-section-content {
        margin-top: 20px;
    }

    .baskan-text {
        font-size: 16px;
        line-height: 1.9;
        color: #495057;
    }

    .baskan-text p {
        margin-bottom: 25px;
        text-align: justify;
    }

    .baskan-photos-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-top: 20px;
    }

    .baskan-photo-item {
        position: relative;
        width: 100%;
        padding-bottom: 100%;
        overflow: hidden;
        border-radius: 0;
        cursor: pointer;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        background: #f0f0f0;
    }

    .baskan-photo-item:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
    }

    .baskan-photo-img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .baskan-photo-item:hover .baskan-photo-img {
        transform: scale(1.05);
    }

    @@media (max-width: 992px) {
        .baskan-left-panel {
            height: auto;
            min-height: 600px;
            padding: 60px 40px;
        }

        .baskan-image-container {
            padding: 60px 40px 0;
        }

        .baskan-image {
            max-width: 700px;
        }

        .baskan-social-icons {
            bottom: 30px;
            left: 30px;
        }

        .baskan-content-panel {
            height: auto;
            min-height: auto;
        }

        .baskan-content {
            padding: 40px 30px;
        }

        .baskan-name {
            font-size: 32px;
        }

        .baskan-nav-tabs {
            flex-wrap: wrap;
        }

        .baskan-nav-tab {
            padding: 20px 25px;
            font-size: 14px;
            min-height: 60px;
        }

        .baskan-photos-grid {
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
        }
    }

    @@media (max-width: 768px) {
        .baskan-left-panel {
            padding: 40px 30px;
            min-height: 500px;
        }

        .baskan-image-container {
            padding: 40px 30px 0;
        }

        .baskan-image {
            max-width: 550px;
        }

        .baskan-social-icons {
            bottom: 30px;
            left: 30px;
        }

        .baskan-social-icons a {
            width: 40px;
            height: 40px;
            font-size: 20px;
        }

        .baskan-content {
            padding: 30px 20px;
        }

        .baskan-name {
            font-size: 28px;
        }

        .baskan-text {
            font-size: 15px;
        }

        .baskan-nav-tab {
            padding: 18px 22px;
            font-size: 13px;
            min-height: 55px;
        }

        .baskan-close-btn {
            width: 60px;
            height: 60px;
            font-size: 20px;
        }

        .baskan-photos-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const tabs = document.querySelectorAll('.baskan-nav-tab');
        const contents = document.querySelectorAll('.baskan-section-content');

        tabs.forEach(tab => {
            tab.addEventListener('click', function(e) {
                // Eğer link gerçek bir sayfa linkiyse (href="#" değilse veya data-tab yoksa), normal geçiş yap
                const href = this.getAttribute('href');
                const dataTab = this.getAttribute('data-tab');
                
                // Eğer href "#" değilse veya data-tab yoksa, normal sayfa geçişine izin ver
                if ((href && href !== '#' && !href.startsWith('#')) || !dataTab) {
                    return; // Normal link geçişine izin ver
                }
                
                e.preventDefault();
                
                tabs.forEach(t => t.classList.remove('active'));
                this.classList.add('active');

                contents.forEach(content => {
                    content.style.display = 'none';
                });

                const targetContent = document.getElementById(dataTab + '-content');
                if (targetContent) {
                    targetContent.style.display = 'block';
                }
            });
        });
    });
</script>
