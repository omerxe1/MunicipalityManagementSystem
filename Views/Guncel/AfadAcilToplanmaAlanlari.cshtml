@model List<kocaaliv2.Models.AfadAcilToplanmaAlani>
@{
    // AFAD Acil Toplanma Alanları sayfası - Alt sayfa layout'unu kullanır
    Layout = "_AltSayfaLayout";
    ViewData["Title"] = "AFAD Acil Toplanma Alanları";
    ViewData["PageTitle"] = "AFAD Acil Toplanma Alanları";
    ViewData["ContentTitle"] = "AFAD ACİL TOPLANMA ALANLARI";

    // Breadcrumb verileri
    ViewBag.Breadcrumbs = new[]
    {
        new { Text = "Anasayfa", Url = (string?)(Url.Action("Index", "Home") ?? "#") },
        new { Text = "Güncel", Url = (string?)"#" },
        new { Text = "AFAD Acil Toplanma Alanları", Url = (string?)null }
    };

    // Hızlı menü öğeleri
    ViewBag.QuickMenuItems = new[]
    {
        new { Text = "Meclis Üyeleri", Url = (string?)(Url.Action("MeclisUyeleri", "Kurumsal") ?? "#"), IsActive = false },
        new { Text = "Meclis Kararları", Url = (string?)(Url.Action("MeclisKararlari", "Kurumsal") ?? "#"), IsActive = false },
        new { Text = "Kocaali Hakkında", Url = (string?)(Url.Action("Hakkinda", "Kocaali") ?? "#"), IsActive = false },
        new { Text = "Nöbetçi Eczaneler", Url = (string?)(Url.Action("NobetciEczaneler", "Guncel") ?? "#"), IsActive = false },
        new { Text = "Haberler", Url = (string?)(Url.Action("Index", "Haberler") ?? "#"), IsActive = false },
        new { Text = "Duyurular", Url = (string?)"#", IsActive = false },
        new { Text = "Etkinlikler", Url = (string?)(Url.Action("Index", "Etkinlik") ?? "#"), IsActive = false },
        new { Text = "Nöbetçi Zabıta Listesi", Url = (string?)"#", IsActive = false },
        new { Text = "AFAD Acil Toplanma Alanları", Url = (string?)(Url.Action("AfadAcilToplanmaAlanlari", "Guncel") ?? "#"), IsActive = true },
        new { Text = "Salon Tahsis", Url = (string?)"#", IsActive = false },
        new { Text = "Ulaşım Bizden Başarı Sizden", Url = (string?)"#", IsActive = false }
    };

    ViewBag.ShowBackButton = true;
}

<!-- AFAD Acil Toplanma Alanları İçerik Alanı -->
<div class="alt-sayfa-content-body">
    <div class="table-responsive">
        <table class="table table-striped table-bordered afad-table">
            <thead>
                <tr>
                    <th>S.NU</th>
                    <th>ADI</th>
                    <th>İLÇE</th>
                    <th>MAHALLE</th>
                    <th>ENLEM</th>
                    <th>BOYLAM</th>
                    <th>ELEKTRİK</th>
                    <th>YOL</th>
                    <th>WC Kanalizasyon</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.SiraNo</td>
                            <td>@item.Adi</td>
                            <td>@item.Ilce</td>
                            <td>@item.Mahalle</td>
                            <td>@(item.Enlem ?? "-")</td>
                            <td>@(item.Boylam ?? "-")</td>
                            <td>@(item.Elektrik ? "VAR" : "YOK")</td>
                            <td>@(item.Yol ? "VAR" : "YOK")</td>
                            <td>@(item.WcKanSistemi ? "VAR" : "YOK")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center">Henüz toplanma alanı kaydı bulunmamaktadır.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .afad-table {
        width: 100%;
        margin-top: 20px;
        background-color: #fff;
        color: #333;
    }
    
    .afad-table thead {
        background-color: #f8f9fa;
    }
    
    .afad-table thead th {
        font-weight: 600;
        text-align: center;
        padding: 12px 8px;
        border: 1px solid #dee2e6;
        font-size: 14px;
    }
    
    .afad-table tbody td {
        padding: 10px 8px;
        text-align: center;
        border: 1px solid #dee2e6;
        font-size: 13px;
    }
    
    .afad-table tbody tr:hover {
        background-color: #f5f5f5;
    }
    
    @@media (max-width: 768px) {
        .table-responsive {
            overflow-x: auto;
        }
        
        .afad-table {
            font-size: 12px;
        }
        
        .afad-table thead th,
        .afad-table tbody td {
            padding: 8px 4px;
            font-size: 11px;
        }
    }
</style>

