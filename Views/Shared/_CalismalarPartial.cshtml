@model List<Calisma>
@using kocaaliv2.Models


<script>
    window.calismalarData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));
    
    function goToProjectDetail() {
        if (window.calismalarData && window.calismalarData.length > 0) {
            // currentProjectIndex'i site.js'ten al
            const currentIndex = (window.ProjectNavigation && window.ProjectNavigation.currentProjectIndex !== undefined) 
                ? window.ProjectNavigation.currentProjectIndex 
                : 0;
            const currentProject = window.calismalarData[currentIndex];
            if (currentProject && currentProject.id) {
                window.location.href = '@Url.Action("ProjeDetay", "HizmetRehberi")?id=' + currentProject.id;
            }
        }
    }
</script>




@if (Model != null && Model.Any())
