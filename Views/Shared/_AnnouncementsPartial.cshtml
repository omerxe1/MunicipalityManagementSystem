@model List<kocaaliv2.Models.Announcement>

<div class="announcements-list">
    @foreach (var item in Model)
    {
        <div class="announcement-item">
            <div class="announcement-content">
                <h5 class="announcement-title">@item.Title</h5>
                <p class="announcement-text">@item.Content</p>
                <small class="announcement-date">@item.PublishDate.ToShortDateString()</small>
            </div>
        </div>
    }
</div>

<style>
.announcements-list {
    display: flex;
    flex-direction: column;
    gap: 15px;
}

.announcement-item {
    background: white;
    border-radius: 8px;
    padding: 15px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.announcement-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(0,0,0,0.15);
}

.announcement-title {
    font-size: 16px;
    font-weight: bold;
    color: #374151;
    margin-bottom: 8px;
    line-height: 1.4;
}

.announcement-text {
    color: #6b7280;
    font-size: 14px;
    line-height: 1.5;
    margin-bottom: 10px;
}

.announcement-date {
    font-size: 12px;
    color: #9ca3af;
}

@@media (max-width: 768px) {
    .announcement-item {
        padding: 12px;
    }
    
    .announcement-title {
        font-size: 15px;
    }
    
    .announcement-text {
        font-size: 13px;
    }
}
</style>
