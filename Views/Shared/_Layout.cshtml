                    <a asp-controller="Kurumsal" asp-action="Kvkk" class="mega-link">KVKK</a>
                    <a href="#" class="mega-link">Kamu Spotu</a>
                  </div>
                </div>
              </div>
            </li>
            <li class="nav-item has-mega position-static" id="nav-kocaali">
              <a class="nav-link" href="#">Kocaali</a>
