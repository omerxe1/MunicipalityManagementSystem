    <script>
      (function() {
        const preloader = document.getElementById('preloader');
        if (!preloader) return;
        
        const minDisplayTime = 500; // Minimum display time in ms
        const fadeOutDuration = 500; // Fade out animation duration
        const startTime = Date.now();
        
        function hidePreloader() {
          if (preloader.classList.contains('hide')) return;
          
          // Add hide class for fade out animation
          preloader.classList.add('hide');
          
          // Remove preloader from DOM after animation completes
          setTimeout(function() {
            preloader.style.display = 'none';
            
            // Logo animasyonunu başlat
            const centerLogo = document.querySelector('.center-logo-slot');
            if (centerLogo) {
              centerLogo.classList.add('show');
            }
            
            // Show popup after preloader is hidden (sadece ilk girişte)
            if (!localStorage.getItem('popupClosed')) {
              showPopupAnnouncements();
            }
          }, fadeOutDuration);
        }
        
        // Hide preloader when page is fully loaded
        window.addEventListener('load', function() {
          const elapsed = Date.now() - startTime;
          const remaining = Math.max(0, minDisplayTime - elapsed);
          
          setTimeout(hidePreloader, remaining);
        });
      })();
    </script>
    
    
    <script>
      // Popup Announcements Data (veritabanından)
      @{
        var popupAnnouncements = ViewBag.PopupAnnouncements as List<kocaaliv2.Models.PopupAnnouncement> ?? new List<kocaaliv2.Models.PopupAnnouncement>();
        var popupDataJson = System.Text.Json.JsonSerializer.Serialize(
          popupAnnouncements.Select(p => new {
            id = p.Id,
            title = p.Title,
            content = new { imageUrl = p.ImageUrl ?? "" },
            icon = p.Icon ?? "fas fa-bullhorn"
          })
        );
      }
      const popupAnnouncementsData = @Html.Raw(popupDataJson);
      
      let currentSelectedAnnouncement = null;
      
      function showPopupAnnouncements() {
        // localStorage kontrolü - eğer daha önce kapatıldıysa gösterme
        if (localStorage.getItem('popupClosed')) {
          return;
        }
        
        const modal = document.getElementById('popupAnnouncementsModal');
        if (!modal) return;
        
        // Load announcements list
        loadPopupAnnouncementsList();
        
        // Select first announcement by default
        if (popupAnnouncementsData.length > 0) {
          selectAnnouncement(popupAnnouncementsData[0].id);
        }
        
        // Show modal
        setTimeout(function() {
          modal.classList.add('show');
        }, 100);
      }
      
      function loadPopupAnnouncementsList() {
        const list = document.getElementById('popupAnnouncementsList');
        if (!list) return;
        
        list.innerHTML = '';
        
        popupAnnouncementsData.forEach(function(announcement) {
          const item = document.createElement('div');
          item.className = 'popup-announcement-item';
          item.dataset.id = announcement.id;
          item.onclick = function() {
            selectAnnouncement(announcement.id);
          };
          
          item.innerHTML = `
            <div class="popup-announcement-item-icon">
              <i class="${announcement.icon}"></i>
            </div>
            <div class="popup-announcement-item-content">
              <h4 class="popup-announcement-item-title">${announcement.title}</h4>
            </div>
          `;
          
          list.appendChild(item);
        });
      }
      
      function selectAnnouncement(id) {
        const announcement = popupAnnouncementsData.find(function(a) {
          return a.id === id;
        });
        
        if (!announcement) return;
        
        currentSelectedAnnouncement = announcement;
        
        // Update active state
        document.querySelectorAll('.popup-announcement-item').forEach(function(item) {
          item.classList.remove('active');
          if (parseInt(item.dataset.id) === id) {
            item.classList.add('active');
          }
        });
        
        // Display announcement details
        displayAnnouncementDetail(announcement);
      }
      
      function displayAnnouncementDetail(announcement) {
        const detailContainer = document.getElementById('popupAnnouncementDetail');
        if (!detailContainer) return;
        
        const content = announcement.content;
        let html = `
          <h2 class="popup-detail-title">${announcement.title}</h2>
          <div class="popup-detail-content">
            <div class="popup-detail-image-container">
        `;
        
        // Görsel gösterimi
        if (content.imageUrl) {
          html += `<img src="${content.imageUrl}" alt="${announcement.title}" class="popup-detail-image">`;
        } else {
          // Görsel yoksa placeholder
          html += `<div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #999; font-size: 16px;">Görsel eklenmemiş</div>`;
        }
        
        html += `
            </div>
          </div>
        `;
        
        detailContainer.innerHTML = html;
      }
      
      // Close button handler
      document.addEventListener('DOMContentLoaded', function() {
        const closeBtn = document.getElementById('closePopupBtn');
        const modal = document.getElementById('popupAnnouncementsModal');
        
        function closePopup() {
          modal.classList.remove('show');
          // localStorage'a kapatıldığını kaydet
          localStorage.setItem('popupClosed', 'true');
        }
        
        if (closeBtn && modal) {
          closeBtn.addEventListener('click', closePopup);
        }
        
        // Close on background click
        if (modal) {
          modal.addEventListener('click', function(e) {
            if (e.target === modal) {
              closePopup();
            }
          });
        }
        
        // Close on ESC key
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape' && modal && modal.classList.contains('show')) {
            closePopup();
          }
        });
      });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
    
</body>
