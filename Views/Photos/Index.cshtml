@model IEnumerable<kocaaliv2.Models.Photo>

@{
    ViewData["Title"] = "Başkan'ın Fotoğrafları";
}

<div class="container mt-4">
    <h2 class="mb-4">Başkan'ın Fotoğrafları</h2>

    @if (Model != null && Model.Any())
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-3 col-sm-6 mb-4">
                    <div class="card h-100">
                        <img src="@item.ImageUrl" class="card-img-top" alt="@item.Title" style="height: 250px; object-fit: cover;">
                        <div class="card-body">
                            <h5 class="card-title">@item.Title</h5>
                            <p class="card-text">
                                <small class="text-muted">@item.UploadDate.ToString("dd.MM.yyyy")</small>
                            </p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <p>Henüz fotoğraf eklenmemiş.</p>
        </div>
    }
</div>

